<mujoco model="golf_course_basic_scene">

  <!-- ========================================================= -->
  <!-- 1. 컴파일 및 물리 옵션 -->
  <!-- ========================================================= -->
  <compiler angle="radian"/>

  <option timestep="0.002"
          gravity="0 0 -9.81"/>

  <!-- ========================================================= -->
  <!-- 2. asset: 색상/재질/텍스처 등 재사용 자원 -->
  <!-- ========================================================= -->
  <asset>

    <!-- 바닥용 재질 -->
    <material name="mat_grass"
              rgba="0.20 0.55 0.20 1"/>

    <!-- 페어웨이용 재질 -->
    <material name="mat_fairway"
              rgba="0.35 0.75 0.35 1"/>

    <!-- 홀컵용 어두운 재질 -->
    <material name="mat_hole"
              rgba="0.02 0.02 0.02 1"/>

    <!-- 깃대용 흰색 재질 -->
    <material name="mat_flag_pole"
              rgba="0.9 0.9 0.9 1"/>

    <!-- 깃발용 빨간색 재질 -->
    <material name="mat_flag"
              rgba="1.0 0.1 0.1 1"/>

    <!-- 골프공용 흰색 재질 -->
    <material name="mat_ball"
              rgba="1 1 1 1"/>

    <!-- 장애물용 갈색 재질 -->
    <material name="mat_obstacle"
              rgba="0.45 0.25 0.12 1"/>

    <!-- 골퍼 target 표시용 파란색 재질 -->
    <material name="mat_golfer_target"
              rgba="0.1 0.3 1.0 0.7"/>

  </asset>

  <!-- ========================================================= -->
  <!-- 3. worldbody: 실제 환경 배치 -->
  <!-- ========================================================= -->
  <worldbody>

    <!-- ----------------------------------------------------- -->
    <!-- 3-1. 조명 -->
    <!-- ----------------------------------------------------- -->
    <light name="sun_light"
           pos="0 -3 8"
           dir="0 0 -1"
           diffuse="0.8 0.8 0.8"/>

    <!-- ----------------------------------------------------- -->
    <!-- 3-2. 카메라 -->
    <!-- ----------------------------------------------------- -->
    <camera name="overview_camera"
            pos="0 -10 7"
            xyaxes="1 0 0 0 0.6 0.8"/>

    <!-- ----------------------------------------------------- -->
    <!-- 3-3. 전체 잔디 바닥 -->
    <!-- ----------------------------------------------------- -->
    <geom name="grass_ground"
          type="plane"
          size="15 15 0.1"
          material="mat_grass"
          friction="1.0 0.005 0.0001"/>

    <!-- ----------------------------------------------------- -->
    <!-- 3-4. 페어웨이 이동 구역 -->
    <!-- ----------------------------------------------------- -->
    <!-- MuJoCo plane은 무한 평면에 가까우므로, 여기서는 얇은 box로
         페어웨이 영역을 시각적으로 표현한다. -->
    <body name="fairway_visual" pos="0 0 0.005">

      <geom name="fairway_area"
            type="box"
            size="2.2 10.0 0.005"
            material="mat_fairway"
            contype="0"
            conaffinity="0"/>

    </body>

    <!-- ----------------------------------------------------- -->
    <!-- 3-5. 홀컵 -->
    <!-- ----------------------------------------------------- -->
    <!-- 실제 구멍을 파는 대신, 검은색 원통으로 위치를 표시한다. -->
    <body name="hole_cup" pos="0 8 0.012">

      <geom name="hole_cup_geom"
            type="cylinder"
            size="0.18 0.01"
            material="mat_hole"
            contype="0"
            conaffinity="0"/>

    </body>

    <!-- ----------------------------------------------------- -->
    <!-- 3-6. 깃대 -->
    <!-- ----------------------------------------------------- -->
    <body name="flag_pole" pos="0 8 0">

      <geom name="flag_pole_geom"
            type="cylinder"
            size="0.025 1.2"
            pos="0 0 1.2"
            material="mat_flag_pole"
            contype="0"
            conaffinity="0"/>

      <geom name="flag_geom"
            type="box"
            size="0.35 0.02 0.18"
            pos="0.35 0 2.1"
            material="mat_flag"
            contype="0"
            conaffinity="0"/>

    </body>

    <!-- ----------------------------------------------------- -->
    <!-- 3-7. 골프공 -->
    <!-- ----------------------------------------------------- -->
    <body name="golf_ball" pos="-0.5 -3 0.08">

      <joint name="golf_ball_free_joint"
             type="free"/>

      <geom name="golf_ball_geom"
            type="sphere"
            size="0.043"
            mass="0.046"
            material="mat_ball"
            friction="0.4 0.005 0.0001"/>

    </body>

    <!-- ----------------------------------------------------- -->
    <!-- 3-8. 골퍼 target marker -->
    <!-- ----------------------------------------------------- -->
    <!-- 초기에는 실제 사람 모델 대신 파란색 원통으로 골퍼 위치를 표현한다. -->
    <body name="golfer_target" pos="0 -5 0.15">

      <geom name="golfer_target_geom"
            type="cylinder"
            size="0.25 0.15"
            material="mat_golfer_target"
            contype="0"
            conaffinity="0"/>

    </body>

    <!-- ----------------------------------------------------- -->
    <!-- 3-9. 장애물 -->
    <!-- ----------------------------------------------------- -->
    <body name="obstacle_tree_01" pos="-1.3 -1.5 0.35">

      <geom name="obstacle_tree_01_geom"
            type="cylinder"
            size="0.22 0.35"
            material="mat_obstacle"/>

    </body>

    <body name="obstacle_tree_02" pos="1.4 1.2 0.35">

      <geom name="obstacle_tree_02_geom"
            type="cylinder"
            size="0.25 0.35"
            material="mat_obstacle"/>

    </body>

    <body name="obstacle_marker_box" pos="0.9 4.0 0.25">

      <geom name="obstacle_marker_box_geom"
            type="box"
            size="0.35 0.35 0.25"
            material="mat_obstacle"/>

    </body>

  </worldbody>

</mujoco>