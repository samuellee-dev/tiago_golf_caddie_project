<mujoco model="tiago golf caddie position scene">

  <!-- ========================================================= -->
  <!-- 1. TIAGo Dual Position 제어 모델 -->
  <!-- ========================================================= -->

  <include file="tiago_dual_position.xml"/>

  <!-- ========================================================= -->
  <!-- 2. 화면 표시 설정 -->
  <!-- ========================================================= -->

  <visual>
    <headlight
      diffuse="0.6 0.6 0.6"
      ambient="0.3 0.3 0.3"
      specular="0 0 0"
    />

    <rgba haze="0.15 0.25 0.35 1"/>

    <global
      azimuth="150"
      elevation="-20"
      realtime="1"
      offwidth="1280"
      offheight="720"
    />
  </visual>

  <!-- ========================================================= -->
  <!-- 3. 골프장 재질 -->
  <!-- ========================================================= -->

  <asset>
    <texture
      type="skybox"
      builtin="gradient"
      rgb1="0.3 0.5 0.7"
      rgb2="0 0 0"
      width="512"
      height="3072"
    />

    <material
      name="mat_grass"
      rgba="0.20 0.55 0.20 1"
    />

    <material
      name="mat_fairway"
      rgba="0.35 0.75 0.35 1"
    />

    <material
      name="mat_hole"
      rgba="0.02 0.02 0.02 1"
    />

    <material
      name="mat_flag_pole"
      rgba="0.9 0.9 0.9 1"
    />

    <material
      name="mat_flag"
      rgba="1.0 0.1 0.1 1"
    />

    <material
      name="mat_ball"
      rgba="1 1 1 1"
    />

    <material
      name="mat_obstacle"
      rgba="0.45 0.25 0.12 1"
    />

    <material
      name="mat_golfer_target"
      rgba="0.1 0.3 1.0 0.7"
    />
  </asset>

  <!-- ========================================================= -->
  <!-- 4. TIAGo + 골프장 통합 환경 -->
  <!-- ========================================================= -->

  <worldbody>

    <!-- ------------------------------------------------------- -->
    <!-- 4-1. TIAGo를 비추는 기존 조명 -->
    <!-- ------------------------------------------------------- -->

    <light
      name="spotlight"
      mode="targetbody"
      target="base_link"
      pos="1 0 10"
    />

    <!-- ------------------------------------------------------- -->
    <!-- 4-2. 골프장 전체 조명 -->
    <!-- ------------------------------------------------------- -->

    <light
      name="golf_sun_light"
      pos="0 -3 8"
      dir="0 0 -1"
      diffuse="0.8 0.8 0.8"
    />

    <!-- ------------------------------------------------------- -->
    <!-- 4-3. 골프장 전체 관찰 카메라 -->
    <!-- ------------------------------------------------------- -->

    <camera
      name="golf_overview_camera"
      pos="0 -12 7"
      xyaxes="1 0 0 0 0.6 0.8"
    />

    <!-- ------------------------------------------------------- -->
    <!-- 4-4. 전체 잔디 바닥 -->
    <!-- 원본 TIAGo Scene의 바닥 높이 -0.99를 유지한다. -->
    <!-- ------------------------------------------------------- -->

    <geom
      name="grass_ground"
      type="plane"
      pos="0 0 -0.99"
      size="15 15 0.1"
      material="mat_grass"
      friction="1.0 0.005 0.0001"
      contype="1"
      conaffinity="1"
    />

    <!-- ------------------------------------------------------- -->
    <!-- 4-5. 페어웨이 시각 영역 -->
    <!-- 바닥보다 0.005m 위에 배치한다. -->
    <!-- ------------------------------------------------------- -->

    <body
      name="fairway_visual"
      pos="0 0 -0.985"
    >
      <geom
        name="fairway_area"
        type="box"
        size="2.2 10.0 0.005"
        material="mat_fairway"
        contype="0"
        conaffinity="0"
      />
    </body>

    <!-- ------------------------------------------------------- -->
    <!-- 4-6. 홀컵 위치 표시 -->
    <!-- ------------------------------------------------------- -->

    <body
      name="hole_cup"
      pos="0 8 -0.978"
    >
      <geom
        name="hole_cup_geom"
        type="cylinder"
        size="0.18 0.01"
        material="mat_hole"
        contype="0"
        conaffinity="0"
      />
    </body>

    <!-- ------------------------------------------------------- -->
    <!-- 4-7. 깃대와 깃발 -->
    <!-- ------------------------------------------------------- -->

    <body
      name="flag_pole"
      pos="0 8 -0.99"
    >
      <geom
        name="flag_pole_geom"
        type="cylinder"
        size="0.025 1.2"
        pos="0 0 1.2"
        material="mat_flag_pole"
        contype="0"
        conaffinity="0"
      />

      <geom
        name="flag_geom"
        type="box"
        size="0.35 0.02 0.18"
        pos="0.35 0 2.1"
        material="mat_flag"
        contype="0"
        conaffinity="0"
      />
    </body>

    <!-- ------------------------------------------------------- -->
    <!-- 4-8. 골프공 -->
    <!-- 초기 중심 높이: -0.99 + 0.08 = -0.91 -->
    <!-- ------------------------------------------------------- -->

    <body
      name="golf_ball"
      pos="-0.5 -3 -0.91"
    >
      <joint
        name="golf_ball_free_joint"
        type="free"
      />

      <geom
        name="golf_ball_geom"
        type="sphere"
        size="0.043"
        mass="0.046"
        material="mat_ball"
        friction="0.4 0.005 0.0001"
      />
    </body>

    <!-- ------------------------------------------------------- -->
    <!-- 4-9. 골퍼 target marker -->
    <!-- 중심 높이: -0.99 + 0.15 = -0.84 -->
    <!-- ------------------------------------------------------- -->

    <body
      name="golfer_target"
      pos="0 -5 -0.84"
    >
      <joint
        name="golfer_target_free_joint"
        type="free"
      />

      <geom
        name="golfer_target_geom"
        type="cylinder"
        size="0.25 0.15"
        mass="1.0"
        material="mat_golfer_target"
        contype="0"
        conaffinity="0"
      />
    </body>

    <!-- ------------------------------------------------------- -->
    <!-- 4-10. 원통형 장애물 1 -->
    <!-- 중심 높이: -0.99 + 0.35 = -0.64 -->
    <!-- ------------------------------------------------------- -->

    <body
      name="obstacle_tree_01"
      pos="-1.3 -1.5 -0.64"
    >
      <geom
        name="obstacle_tree_01_geom"
        type="cylinder"
        size="0.22 0.35"
        material="mat_obstacle"
      />
    </body>

    <!-- ------------------------------------------------------- -->
    <!-- 4-11. 원통형 장애물 2 -->
    <!-- ------------------------------------------------------- -->

    <body
      name="obstacle_tree_02"
      pos="1.4 1.2 -0.64"
    >
      <geom
        name="obstacle_tree_02_geom"
        type="cylinder"
        size="0.25 0.35"
        material="mat_obstacle"
      />
    </body>

    <!-- ------------------------------------------------------- -->
    <!-- 4-12. 박스형 장애물 -->
    <!-- 중심 높이: -0.99 + 0.25 = -0.74 -->
    <!-- ------------------------------------------------------- -->

    <body
      name="obstacle_marker_box"
      pos="0.9 4.0 -0.74"
    >
      <geom
        name="obstacle_marker_box_geom"
        type="box"
        size="0.35 0.35 0.25"
        material="mat_obstacle"
      />
    </body>

  </worldbody>

</mujoco>